{
  "openapi": "3.1.0",
  "info": {
    "title": "Bailian Knowledge Base Service",
    "version": "0.1.0"
  },
  "paths": {
    "/knowledge-bases": {
      "post": {
        "tags": [
          "knowledge-bases"
        ],
        "summary": "Create knowledge base",
        "description": "Create an empty Bailian document retrieval knowledge base. This endpoint only creates the knowledge base metadata and does not upload documents or submit indexing jobs.",
        "operationId": "create_knowledge_base_knowledge_bases_post",
        "requestBody": {
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "$ref": "#/components/schemas/Body_create_knowledge_base_knowledge_bases_post"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/knowledge-bases/documents": {
      "post": {
        "tags": [
          "knowledge-bases"
        ],
        "summary": "Upload document using default index",
        "description": "Upload a local file into the knowledge base specified by BAILIAN_INDEX_ID, INDEX_ID, or IndexID in the environment. This upload flow follows the Bailian document example and uses category_id=default by default. By default the API returns immediately after submitting the indexing job; set wait_for_finish=true only when you want to block until parsing completes. Leave chunk_mode empty for smart chunking; only set separator when chunk_mode is regex.",
        "operationId": "upload_document_to_default_knowledge_base_knowledge_bases_documents_post",
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "$ref": "#/components/schemas/Body_upload_document_to_default_knowledge_base_knowledge_bases_documents_post"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/knowledge-bases/documents/list": {
      "get": {
        "tags": [
          "knowledge-bases"
        ],
        "summary": "List indexed documents using default index",
        "description": "List the documents that have already been imported into the default knowledge base. The index ID is resolved from BAILIAN_INDEX_ID, INDEX_ID, or IndexID in the environment.",
        "operationId": "list_default_index_documents_knowledge_bases_documents_list_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          }
        }
      }
    },
    "/knowledge-bases/retrieve": {
      "post": {
        "tags": [
          "knowledge-bases"
        ],
        "summary": "Retrieve using default index",
        "description": "Search the default knowledge base using the query text and return retrieved chunks. The index ID is resolved from BAILIAN_INDEX_ID, INDEX_ID, or IndexID in the environment.",
        "operationId": "retrieve_with_default_index_knowledge_bases_retrieve_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RetrieveRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/": {
      "get": {
        "summary": "Health Check",
        "operationId": "health_check__get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Body_create_knowledge_base_knowledge_bases_post": {
        "properties": {
          "name": {
            "type": "string",
            "title": "Name"
          },
          "description": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Description"
          },
          "category_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Category Id"
          },
          "chunk_size": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Chunk Size",
            "default": 1500
          },
          "overlap_size": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Overlap Size",
            "default": 200
          },
          "chunk_mode": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Chunk Mode"
          },
          "separator": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Separator"
          },
          "enable_headers": {
            "anyOf": [
              {
                "type": "boolean"
              },
              {
                "type": "null"
              }
            ],
            "title": "Enable Headers",
            "default": false
          },
          "embedding_model_name": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Embedding Model Name",
            "default": "text-embedding-v4"
          },
          "rerank_model_name": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Rerank Model Name",
            "default": "qwen3-rerank"
          }
        },
        "type": "object",
        "required": [
          "name"
        ],
        "title": "Body_create_knowledge_base_knowledge_bases_post"
      },
      "Body_upload_document_to_default_knowledge_base_knowledge_bases_documents_post": {
        "properties": {
          "file": {
            "type": "string",
            "contentMediaType": "application/octet-stream",
            "title": "File"
          },
          "category_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Category Id",
            "default": "default"
          },
          "category_type": {
            "type": "string",
            "title": "Category Type",
            "default": "UNSTRUCTURED"
          },
          "parser": {
            "type": "string",
            "title": "Parser",
            "default": "AUTO_SELECT"
          },
          "original_file_url": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Original File Url"
          },
          "wait_for_finish": {
            "type": "boolean",
            "title": "Wait For Finish",
            "default": false
          },
          "poll_interval_seconds": {
            "type": "integer",
            "title": "Poll Interval Seconds",
            "default": 3
          },
          "timeout_seconds": {
            "type": "integer",
            "title": "Timeout Seconds",
            "default": 300
          },
          "chunk_size": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Chunk Size",
            "default": 1500
          },
          "overlap_size": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Overlap Size",
            "default": 200
          },
          "chunk_mode": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Chunk Mode"
          },
          "separator": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Separator"
          },
          "enable_headers": {
            "anyOf": [
              {
                "type": "boolean"
              },
              {
                "type": "null"
              }
            ],
            "title": "Enable Headers",
            "default": false
          },
          "tags": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Tags"
          }
        },
        "type": "object",
        "required": [
          "file"
        ],
        "title": "Body_upload_document_to_default_knowledge_base_knowledge_bases_documents_post"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "RetrieveRequest": {
        "properties": {
          "query": {
            "type": "string",
            "minLength": 1,
            "title": "Query"
          },
          "dense_similarity_top_k": {
            "type": "integer",
            "minimum": 1.0,
            "title": "Dense Similarity Top K",
            "default": 5
          },
          "sparse_similarity_top_k": {
            "type": "integer",
            "minimum": 1.0,
            "title": "Sparse Similarity Top K",
            "default": 5
          },
          "rerank_top_n": {
            "type": "integer",
            "minimum": 1.0,
            "title": "Rerank Top N",
            "default": 5
          },
          "enable_reranking": {
            "type": "boolean",
            "title": "Enable Reranking",
            "default": true
          },
          "enable_rewrite": {
            "type": "boolean",
            "title": "Enable Rewrite",
            "default": false
          }
        },
        "type": "object",
        "required": [
          "query"
        ],
        "title": "RetrieveRequest"
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "type": "array",
            "title": "Location"
          },
          "msg": {
            "type": "string",
            "title": "Message"
          },
          "type": {
            "type": "string",
            "title": "Error Type"
          },
          "input": {
            "title": "Input"
          },
          "ctx": {
            "type": "object",
            "title": "Context"
          }
        },
        "type": "object",
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError"
      }
    }
  }
}